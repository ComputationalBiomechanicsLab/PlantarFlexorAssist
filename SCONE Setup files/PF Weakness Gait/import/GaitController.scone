								min = 0.0
								max = 10.0
							}
							L0 {
								init_mean = 0.9
								init_std = 0.1
								min = 0.5
								max = 1.1
							}
						}
					}
				}
			}
			ConditionalController {
				states = Swing
				Controller {
					type = ReflexController
					symmetric = 1
					Reflexes {
						Reflex {
							type = MuscleReflex
							target = bifemsh
							delay = 0.010
							min_control_value = 0.0
							KL {
								init_mean = 1.5
								init_std = 0.2
								min = 0.0
								max = 10.0
							}
							L0 {
								init_mean = 1.0
								init_std = 0.1
