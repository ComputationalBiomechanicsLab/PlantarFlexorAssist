							target = vasti
							delay = 0.010
							KL {
								init_mean = 0.6
								init_std = 0.2
								min = 0.0
								max = 10.0
							}
							L0 {
								init_mean = 0.8
								init_std = 0.1
								min = 0.5
								max = 0.85
