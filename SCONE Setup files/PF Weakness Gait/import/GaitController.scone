							delay = 0.005
							KL {
								init_mean = 0.4
								init_std = 0.2
								min = 0.0
								max = 10.0
							}
							L0 {
								init_mean = 1.0
								init_std = 0.1
								min = 0.5
								max = 1.1
							}
							KV {
