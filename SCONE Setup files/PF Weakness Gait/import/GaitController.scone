								min = -0.5
								max = 0.5
							}
							KP {
								init_mean = -1.0
								init_std = 0.1
								min = -10
								max = 10
							}
							KV {
								init_mean = -1.0
								init_std = 0.1
								min = -10
								max = 10
							}
						}
					}
				}
			}
			ConditionalController {
				states = Liftoff
				Controller {
					type = ReflexController
