			ConditionalController {
				states = Landing
				Controller {
					type = ReflexController
					symmetric = 1
					Reflexes {
						Reflex {
							type = MuscleReflex
							target = hamstrings
							delay = 0.005
							KL {
								init_mean = 0.4
								init_std = 0.2
