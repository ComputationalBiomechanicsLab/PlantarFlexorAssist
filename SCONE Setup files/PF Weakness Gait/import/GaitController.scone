						Reflex {
							type = MuscleReflex
							target = glut_max
							delay = 0.005
							KL {
								init_mean = 0.5
								init_std = 0.2
								min = 0.0
								max = 10.0
							}
							L0 {
								init_mean = 1.0
								init_std = 0.1
								min = 0.5
								max = 1.1
							}
						}
						Reflex {
							type = MuscleReflex
							target = vasti
							delay = 0.010
							KL {
								init_mean = 0.6
								init_std = 0.2
								min = 0.0
								max = 10.0
							}
							L0 {
								init_mean = 0.8
